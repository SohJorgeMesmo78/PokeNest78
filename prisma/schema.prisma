generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pokemon {
  id     Int          @id @default(autoincrement())
  numDex Int          @unique
  nome   String
}

model Tipo {
  id      Int         @id @default(autoincrement())
  nome    String      @unique
  ataques Fraqueza[]  @relation("Ataques")
  defesas Fraqueza[]  @relation("Defesas")
}

model Fraqueza {
  id        Int    @id @default(autoincrement())
  idAtaque  Int
  idDefesa  Int
  fraqueza  Int   // Altere para um tipo Int

  tipoAtaque Tipo @relation("Ataques", fields: [idAtaque], references: [id])
  tipoDefesa Tipo @relation("Defesas", fields: [idDefesa], references: [id])
}